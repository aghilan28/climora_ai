{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://climora.ai/schemas/metric.json",
  "title": "Metric",
  "description": "A quantified measurement associated with a finding.",
  "type": "object",
  "required": ["id", "findingId", "name", "value", "unit", "period", "dataNature", "geographicScope", "metadata"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "findingId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 3, "maxLength": 200 },
    "value": { "type": "number" },
    "unit": { "type": "string", "minLength": 1, "maxLength": 50 },
    "period": { "type": "string", "minLength": 4, "maxLength": 100 },
    "dataNature": { "type": "string", "enum": ["Observed", "Modeled", "Projected", "Derived"] },
    "baseline": { "type": "string" },
    "geographicScope": { "type": "string", "minLength": 2, "maxLength": 200 },
    "metadata": {
      "type": "object",
      "properties": {
        "uncertaintyRange": { "type": "string" },
        "statisticalMethod": { "type": "string" },
        "dataSource": { "type": "string" },
        "scenario": { "type": "string" },
        "temporalResolution": { "type": "string" },
        "spatialResolution": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
