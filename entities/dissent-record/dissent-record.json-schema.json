{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://climora.ai/schemas/dissent-record.json",
  "title": "DissentRecord",
  "description": "A formal scientific disagreement with a finding.",
  "type": "object",
  "required": ["id", "findingId", "statement", "confidenceRating", "citationIds", "evidenceIds", "status", "metadata"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "findingId": { "type": "string", "format": "uuid" },
    "statement": { "type": "string", "minLength": 20, "maxLength": 5000 },
    "confidenceRating": { "type": "string", "enum": ["VeryLow", "Low", "Medium", "High", "VeryHigh"] },
    "citationIds": { "type": "array", "items": { "type": "string", "format": "uuid" }, "minItems": 1 },
    "evidenceIds": { "type": "array", "items": { "type": "string", "format": "uuid" }, "minItems": 1 },
    "status": { "type": "string", "enum": ["Active", "Resolved", "Superseded", "Withdrawn"] },
    "metadata": {
      "type": "object",
      "properties": {
        "registeredAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" },
        "resolutionSummary": { "type": "string", "maxLength": 2000 },
        "reviewers": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "additionalProperties": false
}
