{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://climora.ai/schemas/citation.json",
  "title": "Citation",
  "description": "A bibliographic or data reference to a research source.",
  "type": "object",
  "required": ["id", "title", "authors", "year", "citationType", "metadata"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "title": { "type": "string", "minLength": 5, "maxLength": 500 },
    "authors": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "minItems": 1
    },
    "year": { "type": "integer", "minimum": 1800, "maximum": 2100 },
    "journal": { "type": "string" },
    "publisher": { "type": "string" },
    "doi": { "type": "string" },
    "isbn": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "citationType": {
      "type": "string",
      "enum": ["Journal", "Book", "Report", "Dataset", "GovernmentDocument", "ConferencePaper"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "doi": { "type": "string" },
        "isbn": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "volume": { "type": "string" },
        "issue": { "type": "string" },
        "pages": { "type": "string" },
        "publisher": { "type": "string" },
        "abstract": { "type": "string", "maxLength": 5000 },
        "keywords": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "additionalProperties": false
}
