{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://climora.ai/schemas/finding.json",
  "title": "Finding",
  "description": "A formal scientific conclusion supported by evidence, citations, and metrics in the climate knowledge system.",
  "type": "object",
  "required": [
    "id",
    "statement",
    "summary",
    "confidenceRating",
    "likelihoodRating",
    "dataNature",
    "baselinePeriod",
    "topicIds",
    "evidenceIds",
    "citationIds",
    "metricIds",
    "version",
    "createdAt",
    "updatedAt",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Stable globally unique identifier."
    },
    "statement": {
      "type": "string",
      "minLength": 10,
      "maxLength": 5000,
      "description": "The formal scientific statement of the finding."
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000,
      "description": "A concise plain-language summary."
    },
    "confidenceRating": {
      "type": "string",
      "enum": ["VeryLow", "Low", "Medium", "High", "VeryHigh"]
    },
    "likelihoodRating": {
      "type": "string",
      "enum": [
        "ExceptionallyUnlikely",
        "VeryUnlikely",
        "Unlikely",
        "AboutAsLikelyAsNot",
        "Likely",
        "VeryLikely",
        "VirtuallyCertain"
      ]
    },
    "dataNature": {
      "type": "string",
      "enum": ["Observed", "Modeled", "Projected", "Derived"]
    },
    "baselinePeriod": {
      "type": "string",
      "minLength": 4,
      "maxLength": 50,
      "description": "Baseline reference period."
    },
    "topicIds": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "minItems": 1
    },
    "evidenceIds": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "minItems": 1
    },
    "citationIds": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "minItems": 1
    },
    "metricIds": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "minItems": 0
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this finding record."
    },
    "supersedes": {
      "type": "string",
      "format": "uuid"
    },
    "supersededBy": {
      "type": "string",
      "format": "uuid"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "assessmentCycle": { "type": "string" },
        "chapterReference": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "curationNotes": { "type": "string" },
        "language": { "type": "string", "minLength": 2, "maxLength": 2 }
      }
    }
  },
  "additionalProperties": false
}
